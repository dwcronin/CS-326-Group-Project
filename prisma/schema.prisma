generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Event {
  id            String   @id @default(uuid())
  title         String
  description   String
  location      String
  category      String
  startDatetime DateTime
  endDatetime   DateTime
  capacity      Int?
  organizerId   String
  status        String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}