<!-- src/views/events/list.ejs -->
<!--
  Expected locals:
    events        — Event[]
    query         — string  (current search query, may be empty)
    savedEventIds — string[] (IDs the current user has saved; empty for staff/admin)
    session       — IAppBrowserSession
-->

<div class="mb-8">
  <h1 class="text-3xl font-bold text-slate-900 mb-1">Upcoming Events</h1>
  <p class="text-slate-500 text-sm">Browse and search for events in your community.</p>
</div>

<!-- Search form -->
<form method="GET" action="/events" class="mb-8">
  <div class="relative">
    <!-- Search icon -->
    <div class="absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-4.35-4.35M17 11A6 6 0 1 1 5 11a6 6 0 0 1 12 0z" />
      </svg>
    </div>

    <input
      type="text"
      name="q"
      value="<%= query %>"
      placeholder="Search by title, description, location, or category…"
      class="w-full pl-12 pr-4 py-3 border border-slate-300 rounded-xl text-sm shadow-sm bg-white focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-blue-500 transition"
      hx-get="/events"
      hx-trigger="input changed delay:300ms, search"
      hx-target="#event-results"
      hx-push-url="true"
    />
  </div>
</form>

<!-- Results — swapped by HTMX on search input -->
<div id="event-results">
  <%- include('./_list-results', { events, query, savedEventIds, session }) %>
</div>
