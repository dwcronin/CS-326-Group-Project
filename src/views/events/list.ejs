<!-- src/views/events/list.ejs -->
<!--
  Expected locals:
    events        — Event[]
    query         — string  (current search query, may be empty)
    savedEventIds — string[] (IDs the current user has saved; empty for staff/admin)
    session       — IAppBrowserSession
-->

<div class="mb-6">
  <h1 class="text-3xl font-bold text-slate-900 mb-1">Upcoming Events</h1>
  <p class="text-slate-500 text-sm">Browse and search for events in your community.</p>
</div>

<!-- Search form -->
<form method="GET" action="/events" class="mb-6 flex gap-2">
  <input
    type="text"
    name="q"
    value="<%= query %>"
    placeholder="Search by title, description, location, or category…"
    class="flex-1 border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
  />
  <button
    type="submit"
    class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
  >
    Search
  </button>
  <% if (query) { %>
    <a
      href="/events"
      class="px-4 py-2 rounded-lg border border-slate-300 text-slate-600 text-sm font-medium hover:bg-slate-50 no-underline flex items-center"
    >
      Clear
    </a>
  <% } %>
</form>

<!-- Result count -->
<% if (query) { %>
  <p class="text-sm text-slate-500 mb-4">
    <% if (events.length === 0) { %>
      No events matched "<strong class="text-slate-700"><%= query %></strong>".
    <% } else { %>
      <%= events.length %> event<%= events.length === 1 ? "" : "s" %> matched "<strong class="text-slate-700"><%= query %></strong>".
    <% } %>
  </p>
<% } %>

<!-- Event list -->
<% if (events.length === 0 && !query) { %>
  <div class="p-8 text-center border border-slate-200 rounded-2xl bg-white text-slate-500">
    No upcoming events right now. Check back soon!
  </div>
<% } else { %>
  <ul class="space-y-4 list-none p-0 m-0">
    <% events.forEach(function(event) { %>
      <li class="p-5 border border-slate-200 rounded-2xl bg-white shadow-sm flex items-start justify-between gap-4">
        <div class="flex-1 min-w-0">
          <!-- Category badge + title -->
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <span class="inline-block px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide">
              <%= event.category %>
            </span>
            <h2 class="text-lg font-semibold text-slate-900 m-0 leading-snug"><%= event.title %></h2>
          </div>

          <!-- Location + date -->
          <p class="text-sm text-slate-500 mb-1 mt-1">
            <span class="mr-3">&#128205; <%= event.location %></span>
            <span>&#128197; <%= event.startDatetime.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric", year: "numeric", hour: "numeric", minute: "2-digit" }) %></span>
          </p>

          <!-- Description excerpt -->
          <p class="text-sm text-slate-600 m-0 line-clamp-2"><%= event.description %></p>
        </div>

        <!-- Save button (members only) -->
        <% if (session.authenticatedUser && session.authenticatedUser.role === "user") { %>
          <div class="flex-shrink-0">
            <%- include('../save/button', { eventId: event.id, isSaved: savedEventIds.includes(event.id) }) %>
          </div>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } %>
