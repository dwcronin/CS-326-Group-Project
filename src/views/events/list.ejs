<!-- src/views/events/list.ejs -->
<!--
  Expected locals:
    events        — Event[]
    query         — string  (current search query, may be empty)
    savedEventIds — string[] (IDs the current user has saved; empty for staff/admin)
    session       — IAppBrowserSession
-->

<div class="mb-6">
  <h1 class="text-3xl font-bold text-slate-900 mb-1">Upcoming Events</h1>
  <p class="text-slate-500 text-sm">Browse and search for events in your community.</p>
</div>

<!-- Search form -->
<form method="GET" action="/events" class="mb-6 flex gap-2">
  <input
    type="text"
    name="q"
    value="<%= query %>"
    placeholder="Search by title, description, location, or category…"
    class="flex-1 border border-slate-300 rounded-lg px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500"
    hx-get="/events"
    hx-trigger="input changed delay:300ms, search"
    hx-target="#event-results"
    hx-push-url="true"
  />
  <button
    type="submit"
    class="px-4 py-2 rounded-lg bg-blue-600 text-white text-sm font-medium hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
  >
    Search
  </button>
  <% if (query) { %>
    <a
      href="/events"
      class="px-4 py-2 rounded-lg border border-slate-300 text-slate-600 text-sm font-medium hover:bg-slate-50 no-underline flex items-center"
    >
      Clear
    </a>
  <% } %>
</form>

<!-- Results — swapped by HTMX on search input -->
<div id="event-results">
  <%- include('./_list-results', { events, query, savedEventIds, session }) %>
</div>
