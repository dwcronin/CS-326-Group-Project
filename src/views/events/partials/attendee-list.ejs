<section 
  id="attendee-list-panel" 
  class="mt-8"
  x-data="{ open: false }"
>
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold text-gray-900">Attendees</h2>
    <button
      type="button"
      @click="open = !open"
      class="text-sm font-medium text-blue-600 hover:text-blue-800 focus:outline-none transition-colors duration-200"
    >
      <span x-text="open ? 'Hide list' : 'Show list'"></span>
    </button>
  </div>

  <div x-show="open" x-transition>

    <% if (attendees.length > 0) { %>
      <div class="mb-4 grid gap-3 sm:grid-cols-3">
        <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-green-700">Going</p>
          <p class="mt-1 text-2xl font-semibold text-green-800"><%= attendees.filter(a => a.rsvpStatus === 'going').length %></p>
        </div>
        <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-amber-700">Waitlisted</p>
          <p class="mt-1 text-2xl font-semibold text-amber-800"><%= attendees.filter(a => a.rsvpStatus === 'waitlisted').length %></p>
        </div>
        <div class="rounded-lg border border-gray-200 bg-gray-50 px-4 py-3">
          <p class="text-xs font-medium uppercase tracking-wide text-gray-600">Cancelled</p>
          <p class="mt-1 text-2xl font-semibold text-gray-800"><%= attendees.filter(a => a.rsvpStatus === 'cancelled').length %></p>
        </div>
      </div>
    <% } %>

    <% if (attendees.length === 0) { %>
      <div class="rounded-md border border-gray-200 bg-white px-4 py-6 text-sm text-gray-600">
        No active attendees yet.
      </div>
    <% } else { %>
      <%
        const going      = attendees.filter(a => a.rsvpStatus === 'going');
        const waitlisted = attendees.filter(a => a.rsvpStatus === 'waitlisted');
        const cancelled  = attendees.filter(a => a.rsvpStatus === 'cancelled');
      %>

      <% if (going.length > 0) { %>
        <h3 class="text-sm font-semibold text-green-700 mb-2">
          Going
          <span class="ml-1 rounded-full bg-green-100 text-green-800 px-2 py-0.5 text-xs font-medium">
            <%= going.length %>
          </span>
        </h3>
        <div class="overflow-x-auto rounded-lg border border-green-200 bg-white mb-6">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-green-50">
              <tr>
                <th class="px-4 py-3 text-left font-medium text-gray-700">Name</th>
                <th class="px-4 py-3 text-left font-medium text-gray-700">Email</th>
                <th class="px-4 py-3 text-left font-medium text-gray-700">RSVPed at</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% going.forEach(function(a) { %>
                <tr class="hover:bg-green-50 transition-colors duration-150">
                  <td class="px-4 py-3 text-gray-900 font-medium"><%= a.displayName %></td>
                  <td class="px-4 py-3 text-gray-600"><%= a.email %></td>
                  <td class="px-4 py-3 text-gray-500"><%= a.rsvpCreatedAt.toLocaleString("en-US") %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (waitlisted.length > 0) { %>
        <h3 class="text-sm font-semibold text-amber-700 mb-2">
          Waitlisted
          <span class="ml-1 rounded-full bg-amber-100 text-amber-800 px-2 py-0.5 text-xs font-medium">
            <%= waitlisted.length %>
          </span>
        </h3>
        <div class="overflow-x-auto rounded-lg border border-amber-200 bg-white mb-6">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-amber-50">
              <tr>
                <th class="px-4 py-3 text-left font-medium text-gray-700">Name</th>
                <th class="px-4 py-3 text-left font-medium text-gray-700">Email</th>
                <th class="px-4 py-3 text-left font-medium text-gray-700">RSVPed at</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% waitlisted.forEach(function(a) { %>
                <tr class="hover:bg-amber-50 transition-colors duration-150">
                  <td class="px-4 py-3 text-gray-900 font-medium"><%= a.displayName %></td>
                  <td class="px-4 py-3 text-gray-600"><%= a.email %></td>
                  <td class="px-4 py-3 text-gray-500"><%= a.rsvpCreatedAt.toLocaleString("en-US") %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>

      <% if (cancelled.length > 0) { %>
        <h3 class="text-sm font-semibold text-gray-500 mb-2">
          Cancelled
          <span class="ml-1 rounded-full bg-gray-100 text-gray-700 px-2 py-0.5 text-xs font-medium">
            <%= cancelled.length %>
          </span>
        </h3>
        <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
          <table class="min-w-full divide-y divide-gray-200 text-sm">
            <thead class="bg-gray-50">
              <tr>
                <th class="px-4 py-3 text-left font-medium text-gray-700">Name</th>
                <th class="px-4 py-3 text-left font-medium text-gray-700">Email</th>
                <th class="px-4 py-3 text-left font-medium text-gray-700">RSVPed at</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              <% cancelled.forEach(function(a) { %>
                <tr class="hover:bg-gray-50 transition-colors duration-150">
                  <td class="px-4 py-3 text-gray-900 font-medium"><%= a.displayName %></td>
                  <td class="px-4 py-3 text-gray-600"><%= a.email %></td>
                  <td class="px-4 py-3 text-gray-500"><%= a.rsvpCreatedAt.toLocaleString("en-US") %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>
      <% } %>
    <% } %>
  </div>
</section>