<section 
  id="event-lifecycle-panel" 
  class="mb-6 space-y-4"
  x-data="{ animating: false }"
  x-on:htmx:after-swap.window="animating = true; setTimeout(() => animating = false, 600)"
>
  <div class="flex flex-wrap items-center gap-3">
    <span
      :class="{ 'scale-110': animating }"
      class="transition-transform duration-300 inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-semibold <%=
        event.status === 'published'
          ? 'bg-green-100 text-green-800 ring-1 ring-green-300'
          : event.status === 'cancelled'
            ? 'bg-red-100 text-red-800 ring-1 ring-red-300'
            : 'bg-amber-100 text-amber-800 ring-1 ring-amber-300'
      %>"
    >
      <span class="inline-block w-2 h-2 rounded-full <%= 
        event.status === 'published' ? 'bg-green-500' 
        : event.status === 'cancelled' ? 'bg-red-500' 
        : 'bg-amber-500' %>">
      </span>
      <%= event.status.charAt(0).toUpperCase() + event.status.slice(1) %>
    </span>

    <% if (event.status === "draft") { %>
      <form
        method="POST"
        action="/events/<%= event.id %>/status"
        hx-post="/events/<%= event.id %>/status"
        hx-target="#event-lifecycle-panel"
        hx-swap="outerHTML"
      >
        <input type="hidden" name="status" value="published" />
        <button
          type="submit"
          class="bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 transition-colors duration-200"
        >
          Publish Event
        </button>
      </form>
    <% } %>

    <% if (event.status === "published") { %>
      <form
        method="POST"
        action="/events/<%= event.id %>/status"
        hx-post="/events/<%= event.id %>/status"
        hx-target="#event-lifecycle-panel"
        hx-swap="outerHTML"
      >
        <input type="hidden" name="status" value="cancelled" />
        <button
          type="submit"
          class="bg-red-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-red-500 transition-colors duration-200"
        >
          Cancel Event
        </button>
      </form>
    <% } %>

    <% if (event.status !== "draft") { %>
      <button
        type="button"
        hx-get="/events/<%= event.id %>/attendees"
        hx-target="#attendee-list-panel"
        hx-swap="outerHTML"
        hx-indicator="#attendee-loading"
        class="inline-flex items-center gap-1.5 px-4 py-2 rounded-md text-sm font-medium text-gray-700 border border-gray-300 hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-gray-400 transition-colors duration-200"
      >
        View Attendees
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
        </svg>
      </button>
    <% } %>
  </div>

  <p class="text-sm font-medium <%=
    event.status === 'published' ? 'text-green-700'
    : event.status === 'cancelled' ? 'text-red-700'
    : 'text-amber-700'
  %>">
    <% if (event.status === "draft") { %>
      Draft — hidden from members until published.
    <% } else if (event.status === "published") { %>
      Published — visible to members. Cancelling is permanent.
    <% } else { %>
      Cancelled — locked and cannot be restored.
    <% } %>
  </p>

  <% if (errorMessage) { %>
    <%- include("../../partials/error", { message: errorMessage }) %>
  <% } %>
</section>