<div class="max-w-4xl mx-auto py-8 px-4">
  <% const goingCount = attendees.filter((attendee) => attendee.rsvpStatus === "going").length; %>
  <% const waitlistedCount = attendees.filter((attendee) => attendee.rsvpStatus === "waitlisted").length; %>

  <div class="mb-6 flex items-center justify-between gap-4">
    <div>
      <h1 class="text-2xl font-medium text-gray-900">Attendee List</h1>
      <p class="text-sm text-gray-600 mt-1">Event ID: <%= eventId %></p>
    </div>

    <a
      href="/events/<%= eventId %>/edit"
      class="px-4 py-2 rounded-md text-sm font-medium text-gray-700 border border-gray-300 hover:bg-gray-50 no-underline"
    >
      Back to Edit Event
    </a>
  </div>

  <div class="mb-6 grid gap-3 sm:grid-cols-3">
    <div class="rounded-lg border border-gray-200 bg-white px-4 py-3">
      <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Active RSVPs</p>
      <p class="mt-1 text-2xl font-semibold text-gray-900"><%= attendees.length %></p>
    </div>
    <div class="rounded-lg border border-green-200 bg-green-50 px-4 py-3">
      <p class="text-xs font-medium uppercase tracking-wide text-green-700">Going</p>
      <p class="mt-1 text-2xl font-semibold text-green-800"><%= goingCount %></p>
    </div>
    <div class="rounded-lg border border-amber-200 bg-amber-50 px-4 py-3">
      <p class="text-xs font-medium uppercase tracking-wide text-amber-700">Waitlisted</p>
      <p class="mt-1 text-2xl font-semibold text-amber-800"><%= waitlistedCount %></p>
    </div>
  </div>

  <% if (attendees.length === 0) { %>
    <div class="rounded-md border border-gray-200 bg-white px-4 py-6 text-sm text-gray-600">
      No active attendees yet. Once members RSVP, they will appear here in arrival order.
    </div>
  <% } else { %>
    <div class="overflow-x-auto rounded-lg border border-gray-200 bg-white">
      <div class="border-b border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-600">
        Showing active RSVP records only.
      </div>
      <table class="min-w-full divide-y divide-gray-200 text-sm">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-4 py-3 text-left font-medium text-gray-700">Name</th>
            <th class="px-4 py-3 text-left font-medium text-gray-700">Email</th>
            <th class="px-4 py-3 text-left font-medium text-gray-700">Status</th>
            <th class="px-4 py-3 text-left font-medium text-gray-700">Joined</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% attendees.forEach((attendee) => { %>
            <tr>
              <td class="px-4 py-3 text-gray-900"><%= attendee.displayName %></td>
              <td class="px-4 py-3 text-gray-700"><%= attendee.email %></td>
              <td class="px-4 py-3 text-gray-700">
                <span class="<%= attendee.rsvpStatus === 'going' ? 'bg-green-100 text-green-800' : 'bg-amber-100 text-amber-800' %> inline-flex rounded-full px-2.5 py-1 text-xs font-semibold uppercase tracking-wide">
                  <%= attendee.rsvpStatus %>
                </span>
              </td>
              <td class="px-4 py-3 text-gray-700">
                <%= attendee.rsvpCreatedAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  <% } %>
</div>
