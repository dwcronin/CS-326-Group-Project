<%#
  Partial: events/_list-results.ejs
%>

<% if (query) { %>
  <p class="text-sm text-slate-500 mb-4">
    <% if (events.length === 0) { %>
      No events matched "<strong class="text-slate-700"><%= query %></strong>".
    <% } else { %>
      <%= events.length %> event<%= events.length === 1 ? "" : "s" %> matched "<strong class="text-slate-700"><%= query %></strong>".
    <% } %>
  </p>
<% } %>

<% if (events.length === 0 && !query) { %>
  <div class="p-8 text-center border border-slate-200 rounded-2xl bg-white text-slate-500">
    No upcoming events right now. Check back soon!
  </div>
<% } else { %>
  <ul class="space-y-4 list-none p-0 m-0">
    <% events.forEach(function(event) { %>
      <li
        class="p-5 border border-slate-200 rounded-2xl bg-white shadow-sm hover:shadow-md transition-shadow flex flex-col md:flex-row md:items-start md:justify-between gap-4"
        x-data="{ open: false }"
      >
        <div class="flex-1 min-w-0">
          <div class="flex items-center gap-2 mb-1 flex-wrap">
            <span class="inline-block px-2 py-0.5 rounded-full bg-blue-100 text-blue-700 text-xs font-semibold uppercase tracking-wide">
              <%= event.category %>
            </span>

            <span class="inline-block px-2 py-0.5 rounded-full bg-slate-100 text-slate-600 text-xs font-semibold">
              <%= event.status %>
            </span>
          </div>

          <h2 class="text-lg md:text-xl font-semibold text-slate-900 m-0 leading-snug">
            <%= event.title %>
          </h2>

          <p class="text-sm text-slate-500 mb-2 mt-2">
            <span class="mr-3">&#128205; <%= event.location %></span>
            <span>&#128197; <%= event.startDatetime.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric", year: "numeric", hour: "numeric", minute: "2-digit" }) %></span>
          </p>

          <p class="text-sm text-slate-600 m-0 line-clamp-2">
            <%= event.description %>
          </p>

          <div x-show="open" x-cloak class="mt-3 text-sm text-slate-600 space-y-1">
            <p><strong>Ends:</strong> <%= event.endDatetime.toLocaleString() %></p>
            <% if (event.capacity) { %>
              <p><strong>Capacity:</strong> <%= event.capacity %></p>
            <% } else { %>
              <p><strong>Capacity:</strong> No limit</p>
            <% } %>
          </div>

          <div class="mt-4 flex flex-wrap gap-3 items-center">
            <a
              href="/events/<%= event.id %>"
              class="inline-flex items-center px-3 py-2 rounded-lg bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 no-underline"
            >
              View details
            </a>

            <button
              type="button"
              x-on:click="open = !open"
              class="text-sm font-semibold text-slate-600 hover:text-slate-900"
            >
              <span x-show="!open">Quick preview</span>
              <span x-show="open">Hide preview</span>
            </button>
          </div>
        </div>

        <% if (session.authenticatedUser && session.authenticatedUser.role === "user") { %>
          <div class="flex-shrink-0">
            <%- include('../save/button', { eventId: event.id, isSaved: savedEventIds.includes(event.id) }) %>
          </div>
        <% } %>
      </li>
    <% }) %>
  </ul>
<% } %>