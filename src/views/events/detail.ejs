<div class="space-y-6">
  <div class="rounded-xl bg-white border border-slate-200 shadow-sm p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h1 class="text-3xl font-bold text-slate-900"><%= event.title %></h1>
        <p class="mt-2 text-slate-600"><%= event.description %></p>
      </div>

      <span class="px-3 py-1 rounded-full text-sm font-semibold bg-slate-100 text-slate-700">
        <%= event.status %>
      </span>
    </div>

    <div class="mt-6 grid gap-3 text-sm text-slate-700">
      <p><strong>Location:</strong> <%= event.location %></p>
      <p><strong>Category:</strong> <%= event.category %></p>
      <p><strong>Starts:</strong> <%= event.startDatetime.toLocaleString() %></p>
      <p><strong>Ends:</strong> <%= event.endDatetime.toLocaleString() %></p>

      <% if (event.capacity) { %>
        <p><strong>Capacity:</strong> <%= event.capacity %></p>
      <% } else { %>
        <p><strong>Capacity:</strong> No limit</p>
      <% } %>
    </div>

    <div class="mt-6 flex gap-3 flex-wrap">
      <a
        href="/events"
        class="px-4 py-2 rounded-lg bg-white border border-slate-200 text-slate-700 font-semibold hover:bg-slate-50 no-underline"
      >
        Back to Events
      </a>

      <% if (session.authenticatedUser && (session.authenticatedUser.role === "admin" || session.authenticatedUser.role === "staff")) { %>
        <a
          href="/events/<%= event.id %>/edit"
          class="px-4 py-2 rounded-lg bg-blue-600 text-white font-semibold hover:bg-blue-700 no-underline"
        >
          Edit Event
        </a>
      <% } %>

      <% if (session.authenticatedUser && session.authenticatedUser.role === "user" && event.status === "published") { %>
        <%- include('../rsvp/button', { eventId: event.id, rsvpStatus }) %>
        <% } %>
    </div>
  </div>
</div>