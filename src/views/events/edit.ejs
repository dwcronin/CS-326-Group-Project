<div id="edit-form-region" class="max-w-2xl mx-auto py-8 px-4 sm:px-6">

  <div class="mb-6">
    <h1 class="text-2xl sm:text-3xl font-bold text-slate-900">Edit Event</h1>
    <p class="mt-1 text-sm text-slate-500">Changes are saved immediately. Cancelled and past events cannot be edited.</p>
  </div>

  <%- include("partials/lifecycle-panel", { event, session, errorMessage: lifecycleError ?? null, layout: false }) %>

  <% if (errors && errors.length > 0) { %>
    <%- include('../partials/error', { message: errors[0] }) %>
  <% } %>

  <form
    hx-post="/events/<%= event.id %>/edit"
    hx-target="#edit-form-region"
    hx-swap="outerHTML"
    x-data="{
      dirty: false,
      originals: {},
      init() {
        this.$nextTick(() => {
          this.$el.querySelectorAll('input, textarea').forEach(f => {
            this.originals[f.name] = f.value;
            f.addEventListener('input', () => {
              this.dirty = Object.keys(this.originals).some(
                k => {
                  const el = this.$el.querySelector('[name=' + k + ']');
                  return el && el.value !== this.originals[k];
                }
              );
            });
          });
        });
      }
    }"
    x-on:submit="dirty = false"
  >

    <div
      x-show="dirty"
      x-transition.opacity
      class="mb-4 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800"
      style="display: none;"
    >
      ⚠ You have unsaved changes.
    </div>

    <div class="rounded-xl border border-slate-200 bg-white shadow-sm divide-y divide-slate-100">

      <div class="p-4 sm:p-6">
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="title">
          Title <span class="text-red-500">*</span>
        </label>
        <input
          type="text"
          id="title"
          name="title"
          maxlength="100"
          required
          value="<%= fields.title ?? event.title %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="Give your event a clear title"
        />
      </div>

      <div class="p-4 sm:p-6">
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="description">
          Description <span class="text-red-500">*</span>
        </label>
        <textarea
          id="description"
          name="description"
          rows="5"
          maxlength="2000"
          required
          class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="Describe what attendees can expect"
        ><%= fields.description ?? event.description %></textarea>
      </div>

      <div class="p-4 sm:p-6">
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="location">
          Location
        </label>
        <input
          type="text"
          id="location"
          name="location"
          value="<%= fields.location ?? event.location %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="Where is this event taking place?"
        />
      </div>

      <div class="p-4 sm:p-6">
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="category">
          Category
        </label>
        <input
          type="text"
          id="category"
          name="category"
          value="<%= fields.category ?? event.category %>"
          class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
          placeholder="e.g. Music, Sports, Food &amp; Drink"
        />
      </div>

      <div class="p-4 sm:p-6">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="startDatetime">
              Start date &amp; time
            </label>
            <input
              type="datetime-local"
              id="startDatetime"
              name="startDatetime"
              value="<%= fields.startDatetime ?? event.startDatetime.toISOString().slice(0,16) %>"
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>
          <div>
            <label class="block text-sm font-medium text-slate-700 mb-1.5" for="endDatetime">
              End date &amp; time
            </label>
            <input
              type="datetime-local"
              id="endDatetime"
              name="endDatetime"
              value="<%= fields.endDatetime ?? event.endDatetime.toISOString().slice(0,16) %>"
              class="w-full rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
            />
          </div>
        </div>
      </div>

      <div class="p-4 sm:p-6">
        <label class="block text-sm font-medium text-slate-700 mb-1.5" for="capacity">
          Capacity
          <span class="ml-1 font-normal text-slate-400">(leave blank for no limit)</span>
        </label>
        <input
          type="number"
          id="capacity"
          name="capacity"
          min="1"
          value="<%= fields.capacity ?? (event.capacity !== undefined ? event.capacity : '') %>"
          placeholder="No limit"
          class="w-full sm:w-40 rounded-lg border border-slate-300 px-3 py-2 text-sm text-slate-900 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent"
        />
      </div>

    </div>

    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <button
        type="submit"
        class="w-full sm:w-auto px-6 py-2.5 rounded-lg bg-blue-600 text-white text-sm font-semibold hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 transition-colors"
      >
        Save changes
      </button>
      
        href="/events/<%= event.id %>"
        class="w-full sm:w-auto px-6 py-2.5 rounded-lg border border-slate-300 text-slate-700 text-sm font-semibold hover:bg-slate-50 focus:outline-none focus:ring-2 focus:ring-slate-400 focus:ring-offset-2 transition-colors text-center no-underline"
        x-on:click.prevent="
          if (dirty) {
            if (confirm('You have unsaved changes. Leave anyway?')) {
              window.location.href = $el.href;
            }
          } else {
            window.location.href = $el.href;
          }
        "
      >
        Cancel
      </a>
    </div>

  </form>

  <p id="attendee-loading" class="htmx-indicator mt-8 text-sm text-slate-500 opacity-0 transition-opacity">
    Loading attendees…
  </p>
  <section id="attendee-list-panel"></section>

</div>