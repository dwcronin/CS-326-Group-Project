<%#
  src/views/save/saved-list.ejs
  Saved events dashboard for members (Feature 14).

  Expected locals:
    savedEvents — Array<{ savedRecord: SavedEvent, event: Event }>
    session     — IAppBrowserSession
%>

<div class="mb-8 flex items-center gap-3">
  <div class="flex items-center justify-center w-10 h-10 rounded-xl bg-amber-100 shrink-0">
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 fill-amber-500" viewBox="0 0 24 24">
      <path d="M5 3a2 2 0 0 0-2 2v16l9-4 9 4V5a2 2 0 0 0-2-2H5z"/>
    </svg>
  </div>
  <div class="flex-1 min-w-0">
    <h1 class="text-2xl font-bold text-slate-900 leading-tight">Saved Events</h1>
    <p class="text-sm text-slate-500">Your personal collection of events to attend.</p>
  </div>
  <a
    href="/events"
    class="text-sm text-blue-600 font-medium hover:underline no-underline whitespace-nowrap"
  >Browse all &rarr;</a>
</div>

<% if (savedEvents.length === 0) { %>
  <div class="rounded-2xl bg-white border border-slate-200 shadow-sm p-12 text-center">
    <div class="flex items-center justify-center w-14 h-14 rounded-full bg-slate-100 mx-auto mb-4">
      <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 3a2 2 0 0 0-2 2v16l9-4 9 4V5a2 2 0 0 0-2-2H5z"/>
      </svg>
    </div>
    <p class="text-base font-semibold text-slate-700">Nothing saved yet</p>
    <p class="mt-1 text-sm text-slate-500">
      Browse <a href="/events" class="text-blue-600 hover:underline">upcoming events</a>
      and click <strong>Save</strong> on anything that interests you.
    </p>
  </div>
<% } else { %>
  <p class="text-sm text-slate-500 mb-4">
    <%= savedEvents.length %> saved event<%= savedEvents.length === 1 ? "" : "s" %>
  </p>
  <ul class="space-y-4 list-none p-0 m-0">
    <% savedEvents.forEach(({ savedRecord, event }) => { %>
      <li class="rounded-2xl bg-white border border-slate-200 shadow-sm p-5 flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
          <div class="flex items-center gap-2 flex-wrap mb-1">
            <span class="inline-block px-2 py-0.5 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 uppercase tracking-wide">
              <%= event.category %>
            </span>
            <span class="text-xs text-slate-400">
              Saved <%= savedRecord.createdAt.toLocaleDateString("en-US", { month: "short", day: "numeric", year: "numeric" }) %>
            </span>
          </div>
          <h2 class="text-base font-semibold text-slate-900 truncate"><%= event.title %></h2>
          <p class="mt-0.5 text-sm text-slate-500">
            <span class="mr-3">&#128205; <%= event.location %></span>
            <span>&#128197; <%= event.startDatetime.toLocaleDateString("en-US", { weekday: "short", month: "short", day: "numeric" }) %>
              at <%= event.startDatetime.toLocaleTimeString("en-US", { hour: "numeric", minute: "2-digit" }) %></span>
          </p>
        </div>
        <div class="shrink-0 pt-0.5">
          <%- include('button', { eventId: event.id, isSaved: true }) %>
        </div>
      </li>
    <% }) %>
  </ul>
<% } %>
