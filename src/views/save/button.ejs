<%--
  src/views/save/button.ejs
  Reusable save/unsave toggle button for Feature 14.

  Expected locals:
    eventId  — string
    isSaved  — boolean
--%>

<form method="POST" action="/events/<%= eventId %>/save" class="inline">
  <% if (isSaved) { %>
    <button
      type="submit"
      class="px-4 py-2 rounded-md text-sm font-medium bg-amber-500 text-white hover:bg-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-400"
    >
      Saved &#9733; — click to remove
    </button>
  <% } else { %>
    <button
      type="submit"
      class="px-4 py-2 rounded-md text-sm font-medium bg-slate-600 text-white hover:bg-slate-700 focus:outline-none focus:ring-2 focus:ring-slate-500"
    >
      &#9734; Save for later
    </button>
  <% } %>
</form>
