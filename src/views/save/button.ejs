<%#
  src/views/save/button.ejs
  Reusable save/unsave toggle button for Feature 14.

  Expected locals:
    eventId  — string
    isSaved  — boolean
%>

<form
  method="POST"
  action="/events/<%= eventId %>/save"
  class="inline"
  hx-post="/events/<%= eventId %>/save"
  hx-target="this"
  hx-swap="outerHTML"
>
  <% if (isSaved) { %>
    <button
      type="submit"
      title="Remove from saved"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-amber-100 text-amber-700 border border-amber-300 hover:bg-amber-200 focus:outline-none focus:ring-2 focus:ring-amber-400 transition"
    >
      <!-- Solid bookmark -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 fill-amber-500" viewBox="0 0 24 24">
        <path d="M5 3a2 2 0 0 0-2 2v16l9-4 9 4V5a2 2 0 0 0-2-2H5z"/>
      </svg>
      Saved
    </button>
  <% } else { %>
    <button
      type="submit"
      title="Save for later"
      class="inline-flex items-center gap-1.5 px-3 py-1.5 rounded-lg text-sm font-medium bg-white text-slate-600 border border-slate-300 hover:bg-slate-50 hover:border-slate-400 focus:outline-none focus:ring-2 focus:ring-slate-400 transition"
    >
      <!-- Outline bookmark -->
      <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 3a2 2 0 0 0-2 2v16l9-4 9 4V5a2 2 0 0 0-2-2H5z"/>
      </svg>
      Save
    </button>
  <% } %>
</form>
