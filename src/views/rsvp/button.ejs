<!-- src/views/rsvp/button.ejs -->
<!--
  Expected locals:
    eventId    — string
    rsvpStatus — "going" | "waitlisted" | null
-->

<div id="rsvp-button-region">
  <form
    hx-post="/events/<%= eventId %>/rsvp"
    hx-target="#rsvp-button-region"
    hx-swap="outerHTML"
  >
    <% if (rsvpStatus === "going") { %>
      <button
        type="submit"
        class="px-4 py-2 rounded-md text-sm font-medium bg-green-600 text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500"
      >
        Going — click to cancel
      </button>
    <% } else if (rsvpStatus === "waitlisted") { %>
      <button
        type="submit"
        class="px-4 py-2 rounded-md text-sm font-medium bg-yellow-500 text-white hover:bg-yellow-600 focus:outline-none focus:ring-2 focus:ring-yellow-400"
      >
        Waitlisted — click to cancel
      </button>
    <% } else { %>
      <button
        type="submit"
        class="px-4 py-2 rounded-md text-sm font-medium bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500"
      >
        RSVP
      </button>
    <% } %>
  </form>
</div>