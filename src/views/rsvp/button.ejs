<!--
  Expected locals:
    eventId    — string
    rsvpStatus — "going" | "waitlisted" | null
-->

<div
  id="rsvp-button-region"
  x-data="{ status: '<%= rsvpStatus ?? 'none' %>' }"
>
  <form
    hx-post="/events/<%= eventId %>/rsvp"
    hx-target="#rsvp-button-region"
    hx-swap="outerHTML"
    hx-on:htmx:after-swap="
      const el = document.getElementById('rsvp-button-region');
      if (el) el.classList.add('rsvp-updated');
      setTimeout(() => { if (el) el.classList.remove('rsvp-updated'); }, 400);
    "
  >
    <% if (rsvpStatus === "going") { %>
      <button
        type="submit"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200
               bg-green-600 text-white hover:bg-green-700 focus:outline-none focus:ring-2 focus:ring-green-500 focus:ring-offset-2
               active:scale-95"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
        </svg>
        Going — click to cancel
      </button>

    <% } else if (rsvpStatus === "waitlisted") { %>
      <button
        type="submit"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200
               bg-amber-500 text-white hover:bg-amber-600 focus:outline-none focus:ring-2 focus:ring-amber-400 focus:ring-offset-2
               active:scale-95"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2m6-2a10 10 0 11-20 0 10 10 0 0120 0z" />
        </svg>
        Waitlisted — click to cancel
      </button>

    <% } else { %>
      <button
        type="submit"
        class="inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-semibold transition-all duration-200
               bg-blue-600 text-white hover:bg-blue-700 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2
               active:scale-95"
      >
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        RSVP
      </button>
    <% } %>

  </form>
</div>